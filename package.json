{
  "name": "callmux",
  "version": "0.22.0",
  "description": "Multiplexer for MCP tool calls — parallel execution, batching, caching, and pipelining for any MCP server",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "callmux": "dist/bin/callmux.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "assets/dashboard.html",
    "schema.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edimuj/callmux.git"
  },
  "homepage": "https://github.com/edimuj/callmux#readme",
  "bugs": {
    "url": "https://github.com/edimuj/callmux/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dev:dashboard": "npm --prefix dashboard run dev",
    "build:dashboard": "npm --prefix dashboard install --no-audit --no-fund && npm --prefix dashboard run build && node scripts/copy-dashboard-asset.mjs",
    "check:public-surface": "node scripts/check-public-surface.mjs",
    "test": "tsc --project tsconfig.test.json && node --test dist-test/*.test.js",
    "prepack": "npm run build:dashboard",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "multiplexer",
    "parallel",
    "batch",
    "proxy",
    "ai",
    "agents",
    "tool-calls"
  ],
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "author": "Edin Mujkanovic",
  "license": "MIT",
  "overrides": {
    "ip-address": "10.2.0"
  }
}
